generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cliente {
  id           Int           @id @default(autoincrement())
  nombre       String
  telefono     String
  email        String?
  direccion    String?
  notas        String?
  creadoEn     DateTime      @default(now())
  pedidos      Pedido[]
  recordatorios Recordatorio[]
  leads        Lead[]
}

model Lead {
  id              Int            @id @default(autoincrement())
  nombre          String
  telefono        String?
  email           String?
  empresa         String?
  origen          String
  estado          String         @default("nuevo")
  interes         String?
  notas           String?
  proximoContacto DateTime?
  creadoEn        DateTime       @default(now())
  actualizadoEn   DateTime       @updatedAt
  clienteId       Int?
  cliente         Cliente?       @relation(fields: [clienteId], references: [id])
  interacciones   Interaccion[]
}

model Interaccion {
  id       Int      @id @default(autoincrement())
  leadId   Int
  tipo     String
  nota     String
  fecha    DateTime @default(now())
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Material {
  id                    Int          @id @default(autoincrement())
  nombre                String
  tipo                  String
  precioCompra          Float        @default(0)
  precioPorM2           Float
  porcentajeDesperdicio Float        @default(10)
  largoPlaca            Float?
  anchoPlaca            Float?
  proveedor             String?
  color                 String?
  descripcion           String?
  activo                Boolean      @default(true)
  stockActual           Float        @default(0)
  stockMinimo           Float        @default(0)
  unidadStock           String       @default("m2") // "m2" | "unidad"
  items                 ItemPedido[] @relation("ItemMaterial")
  itemsBacha            ItemPedido[] @relation("ItemBacha")
}

model Pedido {
  id               Int            @id @default(autoincrement())
  clienteId        Int
  estado           String         @default("presupuesto")
  estadoTaller     String         @default("pendiente")
  total            Float
  notas            String?
  notasTaller      String?
  fechaInstalacion DateTime?
  fechaEntrega     DateTime?
  creadoEn         DateTime       @default(now())
  actualizadoEn    DateTime       @updatedAt
  cliente          Cliente        @relation(fields: [clienteId], references: [id])
  items            ItemPedido[]
  avances          AvanceTaller[]
}

model AvanceTaller {
  id        Int      @id @default(autoincrement())
  pedidoId  Int
  nota      String
  estado    String
  creadoEn  DateTime @default(now())
  pedido    Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
}

model ItemPedido {
  id            Int       @id @default(autoincrement())
  pedidoId      Int
  materialId    Int
  descripcion   String?
  largo         Float
  ancho         Float
  cantBachas    Int       @default(0)
  cantCortes    Int       @default(0)
  desperdicio   Float     @default(0)
  precioUnit    Float
  precioTotal   Float
  bachaTipo     String?
  bachaId       Int?
  bachaLargo    Float?
  bachaAncho    Float?
  pedido        Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  material      Material  @relation("ItemMaterial", fields: [materialId], references: [id])
  bacha         Material? @relation("ItemBacha", fields: [bachaId], references: [id])
}

model Recordatorio {
  id         Int      @id @default(autoincrement())
  clienteId  Int
  nota       String
  fechaAviso DateTime
  completado Boolean  @default(false)
  creadoEn   DateTime @default(now())
  cliente    Cliente  @relation(fields: [clienteId], references: [id])
}

model Maquina {
  id             Int             @id @default(autoincrement())
  nombre         String
  tipo           String          // "maquina" | "vehiculo"
  descripcion    String?
  activo         Boolean         @default(true)
  creadoEn       DateTime        @default(now())
  mantenimientos Mantenimiento[]
}

model Mantenimiento {
  id           Int       @id @default(autoincrement())
  maquinaId    Int
  tipo         String    // "aceite" | "gomas" | "frenos" | "service" | "reparacion" | "revision" | "otro"
  descripcion  String
  costo        Float     @default(0)
  fecha        DateTime  @default(now())
  proximaFecha DateTime?
  km           Int?
  creadoEn     DateTime  @default(now())
  maquina      Maquina   @relation(fields: [maquinaId], references: [id], onDelete: Cascade)
}
