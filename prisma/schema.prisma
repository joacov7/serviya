generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Categoria {
  id            Int                    @id @default(autoincrement())
  nombre        String
  icono         String
  descripcion   String?
  color         String                 @default("#2563EB")
  activo        Boolean                @default(true)
  creadoEn      DateTime               @default(now())
  profesionales ProfesionalCategoria[]
  solicitudes   Solicitud[]
}

model Profesional {
  id            Int                    @id @default(autoincrement())
  nombre        String
  telefono      String
  email         String?
  descripcion   String?
  zona          String
  disponible    Boolean                @default(true)
  calificacion  Float                  @default(0)
  totalTrabajos Int                    @default(0)
  fotoUrl       String?
  creadoEn      DateTime               @default(now())
  categorias    ProfesionalCategoria[]
  asignaciones  Asignacion[]
  calificaciones Calificacion[]
}

model ProfesionalCategoria {
  profesionalId Int
  categoriaId   Int
  profesional   Profesional @relation(fields: [profesionalId], references: [id], onDelete: Cascade)
  categoria     Categoria   @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@id([profesionalId, categoriaId])
}

model Cliente {
  id          Int         @id @default(autoincrement())
  nombre      String
  telefono    String
  email       String?
  direccion   String?
  creadoEn    DateTime    @default(now())
  solicitudes Solicitud[]
}

model Solicitud {
  id            Int           @id @default(autoincrement())
  clienteId     Int
  categoriaId   Int
  descripcion   String
  direccion     String
  urgencia      String        @default("normal")
  estado        String        @default("pendiente")
  presupuesto   Float?
  notas         String?
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt
  cliente       Cliente       @relation(fields: [clienteId], references: [id])
  categoria     Categoria     @relation(fields: [categoriaId], references: [id])
  asignacion    Asignacion?
  calificacion  Calificacion?
}

model Asignacion {
  id            Int         @id @default(autoincrement())
  solicitudId   Int         @unique
  profesionalId Int
  estado        String      @default("aceptado")
  fechaInicio   DateTime?
  fechaFin      DateTime?
  creadoEn      DateTime    @default(now())
  solicitud     Solicitud   @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  profesional   Profesional @relation(fields: [profesionalId], references: [id])
}

model Calificacion {
  id            Int         @id @default(autoincrement())
  solicitudId   Int         @unique
  profesionalId Int
  puntuacion    Int
  comentario    String?
  creadoEn      DateTime    @default(now())
  solicitud     Solicitud   @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  profesional   Profesional @relation(fields: [profesionalId], references: [id])
}
